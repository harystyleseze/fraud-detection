# ─────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=Fraud Detection API
APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────
# Database
# For local development without Docker: sqlite:///./fraud.db
# For Docker development: postgresql://fraud_user:devpassword@db:5432/fraud_db
# For production: postgresql://fraud_user:STRONG_PASSWORD@db:5432/fraud_db
# ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./fraud.db

# ─────────────────────────────────────────────────────────
# CORS — which origins (frontend URLs) are allowed to call this API
# Comma-separated list
# ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────────────────
# Fraud Detection Thresholds
# Change these to tune sensitivity without touching any code
# ─────────────────────────────────────────────────────────
RAPID_TXN_COUNT=5
RAPID_TXN_WINDOW_SECONDS=60
DAILY_LIMIT_USD=10000.00
LOCATION_JUMP_WINDOW_SECONDS=120